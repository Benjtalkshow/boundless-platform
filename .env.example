# Copy to .env.local and fill in. Values are validated by src/lib/env.ts.
# NEVER commit real secrets. .env.local is gitignored.

# ----- Server (never exposed to the browser) -----

# Origin of the boundless-nestjs backend. The frontend proxies `/api/*` here
# (see next.config.ts) so better-auth httpOnly cookies stay first-party.
BACKEND_URL="http://localhost:8000"

# Stellar Horizon endpoint. The PUBLIC testnet endpoint below is fine for local
# dev. In staging/production this is a MANAGED endpoint whose full value is a
# SECRET (it encodes the provider/key); set it only in the deploy platform and
# never commit or log it.
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"

# Optional Soroban RPC endpoint (managed/secret in production).
# STELLAR_SOROBAN_RPC_URL="https://soroban-testnet.stellar.org"

# Sentry build-time source map upload (CI only; leave blank for local dev).
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# ----- Client (inlined into the browser bundle; must be non-secret) -----

# Same-origin base path the browser calls; rewritten to BACKEND_URL.
NEXT_PUBLIC_API_BASE_PATH="/api"

# Canonical public URL of this app (absolute links, OG tags).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stellar network: TESTNET or PUBLIC.
NEXT_PUBLIC_STELLAR_NETWORK="TESTNET"

# Publishable Sentry DSN (safe in the browser).
# NEXT_PUBLIC_SENTRY_DSN=""
